{
    "name": "amdl",
    "version": "1.0.0",
    "description": "an apple music downloader",
    "author": "reidlab",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "dev": "concurrently 'node --watch dist/src/index.js' 'tsc --watch'",
        "build": "npm run lint && tsc",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
